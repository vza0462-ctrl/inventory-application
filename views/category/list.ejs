<%- include("../partials/head") %>

<section class="section-heading">
  <div>
    <p class="eyebrow">Browse</p>
    <h1>Categories</h1>
  </div>
  <a class="button button-primary" href="/categories/new">New category</a>
</section>

<% if (categories.length === 0) { %>
  <p class="empty-state">No categories yet. Create one to organize your inventory.</p>
<% } else { %>
  <section class="card-grid">
    <% categories.forEach((category) => { %>
      <article class="panel card">
        <div class="card-heading">
          <h2><a href="/categories/<%= category.id %>"><%= category.name %></a></h2>
          <span class="badge"><%= category.item_count %> items</span>
        </div>
        <p><%= category.description %></p>
        <dl class="meta-list">
          <div>
            <dt>Units in stock</dt>
            <dd><%= category.stock_units %></dd>
          </div>
        </dl>
        <div class="inline-actions">
          <a class="text-link" href="/categories/<%= category.id %>">View</a>
          <a class="text-link" href="/categories/<%= category.id %>/edit">Edit</a>
          <a class="text-link text-link-danger" href="/categories/<%= category.id %>/delete">Delete</a>
        </div>
      </article>
    <% }) %>
  </section>
<% } %>

<%- include("../partials/footer") %>
