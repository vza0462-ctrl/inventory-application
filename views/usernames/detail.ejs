<%- include("../partials/head") %>

<section class="section-heading">
  <div>
    <p class="eyebrow">Staff owner detail</p>
    <h1><%= user.username %></h1>
  </div>
  <div class="inline-actions">
    <a class="button" href="/staff/<%= user.id %>/edit">Edit</a>
    <a class="button button-danger" href="/staff/<%= user.id %>/delete">Delete</a>
  </div>
</section>

<section class="panel">
  <div class="section-heading">
    <div>
      <p class="eyebrow">Assigned products</p>
      <h2>Items owned by this staff member</h2>
    </div>
    <a class="button button-primary" href="/items/new">New item</a>
  </div>

  <% if (items.length === 0) { %>
    <p class="empty-state">No items are assigned to this staff owner.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Item</th>
            <th>Category</th>
            <th>SKU</th>
            <th>Qty</th>
            <th>Price</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item) => { %>
            <tr>
              <td><a href="/items/<%= item.id %>"><%= item.itemname %></a></td>
              <td><a href="/categories/<%= item.category_id %>"><%= item.category_name %></a></td>
              <td><%= item.sku %></td>
              <td><%= item.quantity %></td>
              <td><%= formatCurrency(item.price) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>
