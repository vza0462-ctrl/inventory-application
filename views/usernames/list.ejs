<%- include("../partials/head") %>

<section class="section-heading">
  <div>
    <p class="eyebrow">Browse</p>
    <h1>Staff Owners</h1>
  </div>
  <a class="button button-primary" href="/staff/new">New staff owner</a>
</section>

<% if (users.length === 0) { %>
  <p class="empty-state">No staff owners yet. Add one before creating items.</p>
<% } else { %>
  <section class="card-grid">
    <% users.forEach((user) => { %>
      <article class="panel card">
        <div class="card-heading">
          <h2><a href="/staff/<%= user.id %>"><%= user.username %></a></h2>
          <span class="badge"><%= user.item_count %> items</span>
        </div>
        <dl class="meta-list">
          <div>
            <dt>Units in stock</dt>
            <dd><%= user.stock_units %></dd>
          </div>
        </dl>
        <div class="inline-actions">
          <a class="text-link" href="/staff/<%= user.id %>">View</a>
          <a class="text-link" href="/staff/<%= user.id %>/edit">Edit</a>
          <a class="text-link text-link-danger" href="/staff/<%= user.id %>/delete">Delete</a>
        </div>
      </article>
    <% }) %>
  </section>
<% } %>

<%- include("../partials/footer") %>
